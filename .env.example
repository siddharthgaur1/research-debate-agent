# Copy to .env and fill in. Every var below is read by src/config.py.

# --- Required: startup fails loudly if these are missing ---

# LLM API key for agent reasoning (and source-dedup embeddings on OpenAI).
#  - Paid: OpenAI key (sk-...), leave OPENAI_BASE_URL empty.
#  - FREE chat: Groq key (gsk_...) from https://console.groq.com/keys + set
#    OPENAI_BASE_URL and REASONING_MODEL below. (Groq has no embeddings API, so
#    dedup embeddings still need OpenAI or a local server; dedup is a quality
#    feature, not required to produce a debate.)
OPENAI_API_KEY=sk-...

# OpenAI-compatible base URL for chat. Empty = OpenAI. Free options:
#   Groq:   https://api.groq.com/openai/v1   (REASONING_MODEL=llama-3.3-70b-versatile)
#   Ollama: http://localhost:11434/v1
OPENAI_BASE_URL=

# Web search is required — a debate agent with no sources is pointless.
# Tavily has a free tier: https://app.tavily.com (1000 credits/month, no card).
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=tvly-...
# SERPAPI_KEY=...          # only if SEARCH_PROVIDER=serpapi

# Redis URL. OPTIONAL — the runner degrades to in-memory if it is unreachable.
REDIS_URL=redis://localhost:6379/0

# SQLite file holding run history / the audit log of state transitions.
DB_PATH=./data/runs.db

# --- Optional: sensible defaults in src/config.py ---

# Root directory for per-run artifacts (PDF reports).
RUNS_DIR=./runs

# Model used for debate and arbitration.
REASONING_MODEL=gpt-4o

# Cheaper model used for research summarisation.
CHEAP_MODEL=gpt-4o-mini

# Model used to embed sources for near-duplicate detection.
EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB server host/port. Unset uses a local file store at CHROMA_DIR.
# docker-compose provides these as chroma / 8000.
# CHROMA_HOST=chroma
# CHROMA_PORT=8000
CHROMA_DIR=./chroma_db

# Cosine similarity at or above which two sources are treated as duplicates.
DEDUP_THRESHOLD=0.92

# Hard cap on total LLM spend per run, in USD. The run stops when it is hit.
MAX_RUN_COST_USD=2.0

# Hard cap on web-search calls per run.
MAX_SEARCHES_PER_RUN=20

# Search results requested per research subtask.
RESULTS_PER_SUBTASK=5

# Advocate/Critic exchanges before the Bias Checker steps in.
MAX_DEBATE_ROUNDS=2

# Characters of cleaned page text kept per source.
FETCH_CHAR_BUDGET=12000

# Advocate/critic support within this margin of even marks a claim contested.
CONTESTED_MARGIN=0.15

# Fraction of contested claims that trips uncertainty mode.
UNCERTAINTY_RATIO=0.34

# --- Dashboard only ---

# Base URL the Streamlit dashboard uses to reach the API.
# docker-compose provides this as http://api:8000
API_BASE_URL=http://localhost:8000
